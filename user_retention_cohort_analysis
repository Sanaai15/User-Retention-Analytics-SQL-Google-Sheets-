select *
from cohort_users_raw cur 
limit 10;


select *
from cohort_events_raw cer 
limit 10;


with users_cleaned as (
select cur.user_id, cur.promo_signup_flag, cur.signup_datetime,
       replace(replace(trim(cur.signup_datetime),'.','-'),'/','-') as signup_datetime_clean
from cohort_users_raw cur
),
users_parsed as (
select user_id, promo_signup_flag,signup_datetime,signup_datetime_clean,
case
when length(split_part(split_part(signup_datetime_clean, ' ', 1), '-', 3)) = 4
then to_timestamp(signup_datetime_clean, 'dd-mm-yyyy hh24:mi')
else to_timestamp(signup_datetime_clean, 'dd-mm-yy hh24:mi')
end as signup_ts
from users_cleaned
),
events_cleaned as (
select cer.user_id, cer.event_type, cer.revenue,
       replace(replace(trim(cer.event_datetime),'.','-'),'/','-') as event_datetime_clean
from cohort_events_raw cer
),
events_parsed as (
select user_id, event_type, revenue, event_datetime_clean,
case
when length(split_part(split_part(event_datetime_clean, ' ', 1), '-', 3)) = 4
then to_timestamp(event_datetime_clean, 'dd-mm-yyyy hh24:mi')
else to_timestamp(event_datetime_clean, 'dd-mm-yy hh24:mi')
end as event_ts
from events_cleaned
),
cohort_base as (
select e.user_id, u.promo_signup_flag, u.signup_ts, e.event_ts,
date_trunc('month', u.signup_ts)::date as cohort_month,
date_trunc('month', e.event_ts)::date as activity_month,
(
    (extract(year from e.event_ts) - extract(year from u.signup_ts)) * 12
    +
    (extract(month from e.event_ts) - extract(month from u.signup_ts))
) as month_offset
from events_parsed e
join users_parsed u
  on e.user_id = u.user_id
where u.signup_ts is not null
  and e.event_ts is not null
  and e.event_type is not null
  and e.event_type <> 'test_event'
)
select promo_signup_flag, cohort_month, month_offset,
count(distinct user_id) as users_total
from cohort_base 
where activity_month between '2025-01-01' and '2025-06-01'
group by
    promo_signup_flag,
    cohort_month,
    month_offset
order by
    promo_signup_flag,
    cohort_month,
    month_offset;
